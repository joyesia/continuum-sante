generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Document {
  id                     String   @id
  filename               String
  mimeType               String?
  sizeBytes              Int?
  documentType           String
  confidence             Float
  extractedText          String
  actionTitle            String
  actionDescription      String
  observationTitle       String?
  observationDescription String?
  medicationName         String?
  medicationDosage       String?
  source                 String
  createdAt              DateTime @default(now())

  shares                 SharedBrief[]
  treatments             Treatment[]
  reminders              Reminder[] 
}

model Treatment {
  id             String    @id
  documentId     String?
  name           String
  dosage         String?
  instructions   String?
  startDate      DateTime?
  endDate        DateTime?
  durationDays   Int?
  isLongTerm     Boolean   @default(false)
  renewalDate    DateTime?
  nextDoseDate   DateTime?
  status         String    @default("active")
  createdAt      DateTime  @default(now())

  document       Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
}

model Reminder {
  id          String    @id
  documentId  String?
  title       String
  description String?
  dueDate     DateTime
  type        String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())

  document    Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
}

model SharedBrief {
  id                     String      @id
  code                   String
  documentType           String
  actionTitle            String
  actionDescription      String
  observationTitle       String?
  observationDescription String?
  medicationName         String?
  medicationDosage       String?
  source                 String
  createdAt              DateTime    @default(now())
  expiresAt              DateTime
  revokedAt              DateTime?

  documentId             String?
  document               Document?   @relation(fields: [documentId], references: [id], onDelete: SetNull)

  accessLogs             AccessLog[]
}

model AccessLog {
  id          String      @id
  shareId     String
  openedAt    DateTime    @default(now())
  ipAddress   String?
  userAgent   String?

  sharedBrief SharedBrief @relation(fields: [shareId], references: [id], onDelete: Cascade)
}