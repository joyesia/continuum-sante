generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Document {
  id                     String   @id
  filename               String
  mimeType               String?
  sizeBytes              Int?
  documentType           String
  confidence             Float
  extractedText          String
  actionTitle            String
  actionDescription      String
  observationTitle       String?
  observationDescription String?
  medicationName         String?
  medicationDosage       String?
  source                 String
  createdAt              DateTime @default(now())

  shares                 SharedBrief[]
}

model SharedBrief {
  id                     String      @id
  code                   String
  documentType           String
  actionTitle            String
  actionDescription      String
  observationTitle       String?
  observationDescription String?
  medicationName         String?
  medicationDosage       String?
  source                 String
  createdAt              DateTime    @default(now())
  expiresAt              DateTime
  revokedAt              DateTime?

  documentId             String?
  document               Document?   @relation(fields: [documentId], references: [id], onDelete: SetNull)

  accessLogs             AccessLog[]
}

model AccessLog {
  id          String      @id
  shareId     String
  openedAt    DateTime    @default(now())
  ipAddress   String?
  userAgent   String?

  sharedBrief SharedBrief @relation(fields: [shareId], references: [id], onDelete: Cascade)
}