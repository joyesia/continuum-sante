generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model SharedBrief {
  id                     String      @id
  code                   String
  documentType           String
  actionTitle            String
  actionDescription      String
  observationTitle       String?
  observationDescription String?
  medicationName         String?
  medicationDosage       String?
  source                 String
  createdAt              DateTime    @default(now())
  expiresAt              DateTime
  revokedAt              DateTime?

  accessLogs             AccessLog[]
}

model AccessLog {
  id          String      @id
  shareId     String
  openedAt    DateTime    @default(now())
  ipAddress   String?
  userAgent   String?

  sharedBrief SharedBrief @relation(fields: [shareId], references: [id], onDelete: Cascade)
}